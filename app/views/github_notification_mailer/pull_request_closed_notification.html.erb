<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background-color: #f4f4f4;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 20px;
      }
      .content {
        padding: 20px;
        background-color: #fff;
        border: 1px solid #ddd;
        border-radius: 5px;
      }
      .footer {
        margin-top: 20px;
        font-size: 12px;
        color: #777;
        text-align: center;
      }
      a {
        color: #0366d6;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .merged {
        color: #6f42c1;
      }
      .closed {
        color: #cb2431;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h2>GitHub Pull Request <%= @action.capitalize %></h2>
      </div>
      <div class="content">
        <p>
          Pull Request <strong><a href="<%= @pr_url %>"><%= @pr_title %> (#<%= @pr_number %>)</a></strong> 
          in repository <a href="<%= @repository_url %>"><%= @repository_name %></a> 
          has been <span class="<%= @merged ? 'merged' : 'closed' %>"><%= @action %></span> by <strong><%= @closed_by %></strong>.
        </p>
        
        <% if @merged %>
          <p>The changes have been successfully merged into the target branch.</p>
        <% else %>
          <p>The pull request was closed without being merged.</p>
        <% end %>
        
        <p>
          <a href="<%= @pr_url %>">View Pull Request</a>
        </p>
      </div>
      <div class="footer">
        <p>This is an automated notification from your GitHub webhook integration.</p>
      </div>
    </div>
  </body>
</html>
