 <!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background-color: #f4f4f4;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 20px;
      }
      .content {
        padding: 20px;
        background-color: #fff;
        border: 1px solid #ddd;
        border-radius: 5px;
      }
      .footer {
        margin-top: 20px;
        font-size: 12px;
        color: #777;
        text-align: center;
      }
      a {
        color: #0366d6;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h2>GitHub Push Event Notification</h2>
      </div>
      <div class="content">
        <% if @deleted %>
          <p><strong><%= @pusher_name %></strong> has deleted branch <strong><%= @branch_name %></strong> in repository <a href="<%= @repository_url %>"><%= @repository_name %></a>.</p>
        <% else %>
          <p><strong><%= @pusher_name %></strong> has pushed to branch <strong><%= @branch_name %></strong> in repository <a href="<%= @repository_url %>"><%= @repository_name %></a>.</p>
          
          <p>You can view the changes here: <a href="<%= @compare_url %>">View Changes</a></p>
        <% end %>
        
        <p>Reference: <%= @ref %></p>
      </div>
      <div class="footer">
        <p>This is an automated notification from your GitHub webhook integration.</p>
      </div>
    </div>
  </body>
</html>